import Mathlib
import Pythia.Basic
import Pythia.GaussianSmallBall
import Pythia.SubGaussianMG

namespace Pythia

open MeasureTheory ProbabilityTheory

/-- The canonical MeasurableSpace on `‚Ñï ‚Üí ‚Ñù`: the product sigma-
algebra from the per-coordinate Borel sigma-algebra on `‚Ñù`. Named
for downstream reuse in `canonicalFiltration` + `gaussianWalk`. -/
instance canonicalMeasurableSpace : MeasurableSpace (‚Ñï ‚Üí ‚Ñù) :=
  MeasurableSpace.pi

/-- The product measure `Œº_‚Ñù‚Ñï = ‚®Ç_{n ‚àà ‚Ñï} gaussianReal 0 œÉ¬≤` on
`‚Ñù^‚Ñï`: the canonical iid-standard-Gaussian-increment space. -/
noncomputable def gaussianProductMeasure (œÉ : ‚Ñù) :
    @Measure (‚Ñï ‚Üí ‚Ñù) canonicalMeasurableSpace :=
  Measure.infinitePiNat (fun _ => gaussianReal 0 (Real.toNNReal (œÉ ^ 2)))

/-- The Gaussian product measure is a finite measure (in fact a
probability measure). -/
noncomputable instance (œÉ : ‚Ñù) :
    IsFiniteMeasure (gaussianProductMeasure œÉ) := by
  unfold gaussianProductMeasure
  exact inferInstanceAs (IsFiniteMeasure (Measure.infinitePiNat _))

/-- The canonical filtration on `‚Ñù^‚Ñï`: `ùìï_n` is the œÉ-algebra
generated by the first `n+1` coordinate projections.  Adapted
processes are those whose `t`-th coordinate depends only on the
first `t` increments. -/
noncomputable def canonicalFiltration :
    Filtration ‚Ñï canonicalMeasurableSpace where
  seq n := ‚®Ü (j : ‚Ñï) (_ : j ‚â§ n),
    MeasurableSpace.comap (fun (œâ : ‚Ñï ‚Üí ‚Ñù) => œâ j) (borel ‚Ñù)
  mono' i j hij :=
    iSup_mono fun k => iSup_mono' fun hk => ‚ü®le_trans hk hij, le_rfl‚ü©
  le' n := iSup_le fun j => iSup_le fun _ => (measurable_pi_apply j).comap_le

/-- The Gaussian random walk: `M_t œâ = Œ£_{i < t} œâ i`.  On the
canonical-filtration / gaussian-product measure space this is a
`SubGaussianMG` instance. -/
noncomputable def gaussianWalk (t : ‚Ñï) (œâ : ‚Ñï ‚Üí ‚Ñù) : ‚Ñù :=
  (Finset.range t).sum (fun i => œâ i)

/-- The iid-standard-Gaussian random walk realises our
`SubGaussianMG` structure with parameter `œÉ`.  This provides the
explicit non-vacuous witness that the deployment-slack theorems
quantify over.

